# Backend Environment Variables Example
# Copy this file to .env and update the values

# Database Connection
ConnectionStrings__DefaultConnection=Server=localhost;Database=MoodTrackerDb;Trusted_Connection=True;

# For Docker deployment with SQL Server container:
# ConnectionStrings__DefaultConnection=Server=db;Database=MoodTrackerDb;User Id=sa;Password=YourStrong@Password123;TrustServerCertificate=True;

# ASP.NET Core Settings
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
